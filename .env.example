# Solana 网络配置
SOLANA_NETWORK=DEVNET
SOLANA_RPC_URL=https://api.devnet.solana.com
ROBOT_STATE_PROGRAM_ID=ARjXV5jAyB1t53WE4c3eEf6gftFnF7aiympwBCfSvVoY

# 支付模式 (mock 或 real)
PAYMENT_MODE=mock

# API Keys (PAYMENT_MODE=real 时需要)
LIFI_API_KEY=
MAGIC_BLOCK_API_KEY=
X402_API_KEY=
PAYMENT_RECEIVER_ADDRESS=

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# LLM 配置 (Ollama)
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=gemma4:latest
USE_LLM_MOCK=false

# 前端配置 (构建时使用)
REACT_APP_API_BASE=http://localhost:3002/api
REACT_APP_WS_BASE=ws://localhost:3002
REACT_APP_SOLANA_RPC_URL=https://api.devnet.solana.com

# 机器人通信模式 (http 或 mqtt)
ROBOT_COMMUNICATION_MODE=http
ROBOT_IP=192.168.4.1

# MQTT 配置 (ROBOT_COMMUNICATION_MODE=mqtt 时需要)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=robot

# Cloudflared 配置
CLOUDFLARE_DOMAIN=
