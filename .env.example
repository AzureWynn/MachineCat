# Solana 网络配置
SOLANA_NETWORK=DEVNET
SOLANA_RPC_URL=https://api.devnet.solana.com
ROBOT_STATE_PROGRAM_ID=ARjXV5jAyB1t53WE4c3eEf6gftFnF7aiympwBCfSvVoY

# 支付模式 (mock 或 real)
PAYMENT_MODE=mock

# API Keys (PAYMENT_MODE=real 时需要)
LIFI_API_KEY=
MAGIC_BLOCK_API_KEY=
X402_API_KEY=
PAYMENT_RECEIVER_ADDRESS=

# OpenAI 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# LLM 配置 (Ollama)
# 本地开发：使用本机运行的 ollama 服务 (http://localhost:11434)
# Docker 部署：使用 docker-compose 中的 robot-ollama 服务 (http://ollama:11434)
# 注意：本地开发时请确保 ollama 服务已启动 (ollama serve)
LLM_API_URL=http://localhost:11434/api/generate
LLM_MODEL=gemma4:latest
USE_LLM_MOCK=false

# 前端配置 (构建时使用)
REACT_APP_API_BASE=http://localhost:3002/api
REACT_APP_WS_BASE=ws://localhost:3002
REACT_APP_SOLANA_RPC_URL=https://api.devnet.solana.com

# Cloudflared 配置
CLOUDFLARE_DOMAIN=
